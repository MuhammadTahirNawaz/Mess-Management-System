@{
    ViewData["Title"] = "Delete Account";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-danger">
                <div class="card-header bg-danger text-white text-center">
                    <h2 class="mb-0"><i class="bi bi-exclamation-triangle-fill"></i> Delete Account</h2>
                </div>
                <div class="card-body">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show">
                            <i class="bi bi-x-circle"></i> @TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                        </div>
                    }

                    <div class="alert alert-danger">
                        <h5><i class="bi bi-exclamation-octagon"></i> Warning!</h5>
                        <p class="mb-2"><strong>This action is PERMANENT and CANNOT be undone!</strong></p>
                        <ul class="mb-0">
                            <li>Your account will be permanently deleted</li>
                            <li>All your attendance records will be removed</li>
                            <li>All your payment history will be deleted</li>
                            <li>All your complaints will be removed</li>
                            <li>Your QR code will stop working</li>
                        </ul>
                    </div>

                    <div class="alert alert-info">
                        <i class="bi bi-info-circle"></i> <strong>Note:</strong> You cannot delete your account if you have unpaid bills. Please clear all dues first.
                    </div>

                    <form asp-action="DeleteAccountConfirm" method="post" onsubmit="return confirmDelete()">
                        <div class="mb-3">
                            <label for="password" class="form-label">
                                <i class="bi bi-lock"></i> Enter Your Password to Confirm
                            </label>
                            <input type="password" class="form-control" id="password" name="password" required placeholder="Enter your password">
                        </div>

                        <div class="form-check mb-3">
                            <input class="form-check-input" type="checkbox" id="confirmCheck" required>
                            <label class="form-check-label" for="confirmCheck">
                                I understand that this action is permanent and cannot be reversed
                            </label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-danger btn-lg">
                                <i class="bi bi-trash"></i> Delete My Account Permanently
                            </button>
                            <a asp-action="Dashboard" class="btn btn-secondary">
                                <i class="bi bi-x-circle"></i> Cancel
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function confirmDelete() {
            return confirm('Are you absolutely sure you want to delete your account? This action CANNOT be undone!');
        }
    </script>
}

<style>
    .card {
        animation: shake 0.5s;
    }

    @@keyframes shake {
        0%, 100% { transform: translateX(0); }
        10%, 30%, 50%, 70%, 90% { transform: translateX(-5px); }
        20%, 40%, 60%, 80% { transform: translateX(5px); }
    }
</style>
