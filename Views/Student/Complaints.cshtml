@model List<Semester_Project.Models.Complaint>
@{
    ViewData["Title"] = "My Complaints";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary mb-0"><i class="bi bi-chat-left-text me-2"></i>My Complaints</h2>
        <div>
            <button class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#newComplaintModal">
                <i class="bi bi-plus-circle me-1"></i>New Complaint
            </button>
            <a asp-action="Dashboard" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
            </a>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>You haven't submitted any complaints yet. Click "New Complaint" to submit one.
        </div>
    }
    else
    {
        <div class="row">
            @foreach (var complaint in Model)
            {
                <div class="col-md-6 mb-3">
                    <div class="card shadow-sm h-100">
                        <div class="card-header d-flex justify-content-between align-items-center 
                            @(complaint.Status == "Resolved" ? "bg-success text-white" : 
                              complaint.Status == "InProgress" ? "bg-info text-white" : 
                              complaint.Status == "Closed" ? "bg-secondary text-white" : "bg-warning")">
                            <span><i class="bi bi-receipt me-2"></i><strong>@complaint.Subject</strong></span>
                            <span class="badge 
                                @(complaint.Status == "Resolved" ? "bg-light text-success" : 
                                  complaint.Status == "InProgress" ? "bg-light text-info" : 
                                  complaint.Status == "Closed" ? "bg-light text-secondary" : "bg-light text-warning")">
                                @complaint.Status
                            </span>
                        </div>
                        <div class="card-body">
                            <p class="card-text">@complaint.Description</p>
                            
                            @if (!string.IsNullOrEmpty(complaint.AdminResponse))
                            {
                                <div class="alert alert-light border">
                                    <strong><i class="bi bi-reply me-1"></i>Admin Response:</strong>
                                    <p class="mb-0 mt-1">@complaint.AdminResponse</p>
                                </div>
                            }
                            
                            <small class="text-muted">
                                <i class="bi bi-clock me-1"></i>Submitted: @complaint.CreatedAt.ToString("dd MMM yyyy, hh:mm tt")
                            </small>
                            
                            @if (complaint.ResolvedAt.HasValue)
                            {
                                <br />
                                <small class="text-success">
                                    <i class="bi bi-check-circle me-1"></i>Resolved: @complaint.ResolvedAt.Value.ToString("dd MMM yyyy, hh:mm tt")
                                </small>
                            }
                        </div>
                        @{
                            var status = complaint.Status?.Trim() ?? "Pending";
                            var canDelete = status != "Resolved" && status != "Closed";
                        }
                        @if (canDelete)
                        {
                            <div class="card-footer">
                                <button class="btn btn-sm btn-danger" onclick="deleteComplaint(@complaint.Id)">
                                    <i class="bi bi-trash me-1"></i>Delete
                                </button>
                            </div>
                        }
                    </div>
                </div>
            }
        </div>
    }
</div>

<!-- New Complaint Modal -->
<div class="modal fade" id="newComplaintModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Submit New Complaint</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="complaintForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="subject" class="form-label"><strong>Subject</strong></label>
                        <input type="text" class="form-control" id="subject" name="subject" maxlength="100" required>
                    </div>
                    <div class="mb-3">
                        <label for="description" class="form-label"><strong>Description</strong></label>
                        <textarea class="form-control" id="description" name="description" rows="4" maxlength="1000" required></textarea>
                        <small class="text-muted">Please provide detailed information about your complaint</small>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Submit Complaint</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        $(document).ready(function () {
            $('#complaintForm').on('submit', function (e) {
                e.preventDefault();

                const subject = $('#subject').val();
                const description = $('#description').val();
                const token = $('#complaintForm input[name="__RequestVerificationToken"]').val();

                $.ajax({
                    url: '@Url.Action("SubmitComplaint", "Student")',
                    type: 'POST',
                    data: {
                        subject: subject,
                        description: description,
                        __RequestVerificationToken: token
                    },
                    success: function (response) {
                        if (response.success) {
                            $('#newComplaintModal').modal('hide');
                            Swal.fire({
                                icon: 'success',
                                title: 'Success!',
                                text: response.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: response.message
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error details:', xhr.responseText);
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: 'An error occurred while submitting your complaint'
                        });
                    }
                });
            });
        });

        function deleteComplaint(id) {
            Swal.fire({
                title: 'Delete Complaint?',
                text: 'This action cannot be undone!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                confirmButtonColor: '#d33',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteComplaint", "Student")',
                        type: 'POST',
                        data: { id: id },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Deleted!',
                                    text: response.message,
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => {
                                    window.location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error!',
                                    text: response.message
                                });
                            }
                        },
                        error: function () {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: 'An error occurred while deleting the complaint'
                            });
                        }
                    });
                }
            });
        }
    </script>
}
