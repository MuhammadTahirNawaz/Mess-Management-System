@model dynamic
@{
    ViewData["Title"] = "My Bills";
    var attendancesList = ((IEnumerable<dynamic>)Model.Attendances).ToList();
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary mb-0"><i class="bi bi-receipt me-2"></i>My Mess Bills</h2>
        <a asp-action="Dashboard" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow bg-danger text-white h-100">
                <div class="card-body text-center">
                    <i class="bi bi-exclamation-triangle" style="font-size: 2.5rem;"></i>
                    <h6 class="card-title mt-2">Amount Due</h6>
                    <h2 class="mb-0">PKR @Model.UnpaidAmount.ToString("N2")</h2>
                    <p class="small mb-0 mt-2">@Model.UnpaidMeals unpaid meals</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow bg-success text-white h-100">
                <div class="card-body text-center">
                    <i class="bi bi-check-circle" style="font-size: 2.5rem;"></i>
                    <h6 class="card-title mt-2">Amount Paid</h6>
                    <h2 class="mb-0">PKR @Model.PaidAmount.ToString("N2")</h2>
                    <p class="small mb-0 mt-2">@Model.PaidMeals paid meals</p>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow bg-info text-white h-100">
                <div class="card-body text-center">
                    <i class="bi bi-calculator" style="font-size: 2.5rem;"></i>
                    <h6 class="card-title mt-2">Total Expenses</h6>
                    <h2 class="mb-0">PKR @Model.TotalAmount.ToString("N2")</h2>
                    <p class="small mb-0 mt-2">@Model.TotalMeals total meals</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Payment Instructions -->
    @if (Model.UnpaidAmount > 0)
    {
        <div class="alert alert-warning shadow">
            <h5 class="alert-heading"><i class="bi bi-info-circle me-2"></i>Payment Instructions</h5>
            <p class="mb-2">You have an outstanding balance of <strong>PKR @Model.UnpaidAmount.ToString("N2")</strong> for @Model.UnpaidMeals meal(s).</p>
            <hr>
            <p class="mb-0">
                <i class="bi bi-arrow-right me-2"></i>Please visit the mess office to make payment.<br>
                <i class="bi bi-arrow-right me-2"></i>Show your Permanent ID: <strong class="text-primary">@Model.PermanentID</strong><br>
                <i class="bi bi-arrow-right me-2"></i>Office Hours: Monday - Friday, 9:00 AM - 5:00 PM
            </p>
        </div>
    }
    else
    {
        <div class="alert alert-success shadow">
            <h5 class="alert-heading"><i class="bi bi-check-circle me-2"></i>All Bills Cleared!</h5>
            <p class="mb-0">Excellent! You have no outstanding balance. All your bills are up to date.</p>
        </div>
    }

    <!-- Student Info -->
    <div class="card shadow mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>Account Information</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-2"><strong>Name:</strong> @Model.StudentName</p>
                    <p class="mb-2"><strong>Email:</strong> @Model.StudentEmail</p>
                    <p class="mb-0"><strong>Permanent ID:</strong> <span class="text-primary fw-bold" style="letter-spacing: 1px;">@Model.PermanentID</span></p>
                </div>
                <div class="col-md-6">
                    <p class="mb-2"><strong>Total Meals Consumed:</strong> <span class="badge bg-info fs-6">@Model.TotalMeals</span></p>
                    <p class="mb-2"><strong>Unpaid Meals:</strong> <span class="badge bg-warning fs-6">@Model.UnpaidMeals</span></p>
                    <p class="mb-0"><strong>Paid Meals:</strong> <span class="badge bg-success fs-6">@Model.PaidMeals</span></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Meal History -->
    <div class="card shadow">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Complete Meal History</h5>
        </div>
        <div class="card-body">
            @if (attendancesList.Count == 0)
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>You haven't consumed any meals yet. Start using your mess card!
                </div>
            }
            else
            {
                <!-- Meal Type Filter Tabs -->
                <ul class="nav nav-pills mb-3" role="tablist">
                    <li class="nav-item" role="presentation">
                        <button class="nav-link active" id="all-tab" data-bs-toggle="pill" data-bs-target="#all" type="button" role="tab">
                            <i class="bi bi-list-ul me-1"></i>All (@Model.TotalMeals)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="unpaid-tab" data-bs-toggle="pill" data-bs-target="#unpaid" type="button" role="tab">
                            <i class="bi bi-x-circle me-1"></i>Unpaid (@Model.UnpaidMeals)
                        </button>
                    </li>
                    <li class="nav-item" role="presentation">
                        <button class="nav-link" id="paid-tab" data-bs-toggle="pill" data-bs-target="#paid" type="button" role="tab">
                            <i class="bi bi-check-circle me-1"></i>Paid (@Model.PaidMeals)
                        </button>
                    </li>
                </ul>

                <div class="tab-content">
                    <!-- All Meals Tab -->
                    <div class="tab-pane fade show active" id="all" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-secondary">
                                    <tr>
                                        <th>#</th>
                                        <th>Date</th>
                                        <th>Day</th>
                                        <th>Meal</th>
                                        <th>Amount</th>
                                        <th>Status</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{int idx = 1;}
                                    @foreach (var attendance in attendancesList)
                                    {
                                        <tr class="@(attendance.IsPaid ? "" : "table-warning")">
                                            <td>@idx</td>
                                            <td><strong>@attendance.Date.ToString("dd MMM yyyy")</strong></td>
                                            <td>@attendance.Date.ToString("dddd")</td>
                                            <td>
                                                @if (attendance.MealType == "Breakfast")
                                                {
                                                    <span class="badge bg-warning text-dark"><i class="bi bi-sunrise me-1"></i>Breakfast</span>
                                                }
                                                else if (attendance.MealType == "Lunch")
                                                {
                                                    <span class="badge bg-info"><i class="bi bi-sun me-1"></i>Lunch</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-dark"><i class="bi bi-moon me-1"></i>Dinner</span>
                                                }
                                            </td>
                                            <td><strong>PKR @attendance.Amount.ToString("N2")</strong></td>
                                            <td>
                                                @if (attendance.IsPaid)
                                                {
                                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Paid</span>
                                                    if (attendance.PaidAt.HasValue)
                                                    {
                                                        <br><small class="text-muted">@attendance.PaidAt.Value.ToString("dd MMM")</small>
                                                    }
                                                }
                                                else
                                                {
                                                    <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Unpaid</span>
                                                }
                                            </td>
                                        </tr>
                                        idx++;
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-light">
                                        <td colspan="4" class="text-end"><strong>Grand Total:</strong></td>
                                        <td><strong class="text-primary">PKR @Model.TotalAmount.ToString("N2")</strong></td>
                                        <td>@Model.TotalMeals meals</td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- Unpaid Meals Tab -->
                    <div class="tab-pane fade" id="unpaid" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover table-warning">
                                <thead class="table-warning">
                                    <tr>
                                        <th>#</th>
                                        <th>Date</th>
                                        <th>Day</th>
                                        <th>Meal</th>
                                        <th>Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{int unpaidIdx = 1;}
                                    @{var unpaidAttendances = attendancesList.Where(a => !a.IsPaid).ToList();}
                                    @foreach (var attendance in unpaidAttendances)
                                    {
                                        <tr>
                                            <td>@unpaidIdx</td>
                                            <td><strong>@attendance.Date.ToString("dd MMM yyyy")</strong></td>
                                            <td>@attendance.Date.ToString("dddd")</td>
                                            <td>
                                                @if (attendance.MealType == "Breakfast")
                                                {
                                                    <span class="badge bg-warning text-dark"><i class="bi bi-sunrise me-1"></i>Breakfast</span>
                                                }
                                                else if (attendance.MealType == "Lunch")
                                                {
                                                    <span class="badge bg-info"><i class="bi bi-sun me-1"></i>Lunch</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-dark"><i class="bi bi-moon me-1"></i>Dinner</span>
                                                }
                                            </td>
                                            <td><strong class="text-danger">PKR @attendance.Amount.ToString("N2")</strong></td>
                                        </tr>
                                        unpaidIdx++;
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-light">
                                        <td colspan="4" class="text-end"><strong>Total Due:</strong></td>
                                        <td><strong class="text-danger">PKR @Model.UnpaidAmount.ToString("N2")</strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>

                    <!-- Paid Meals Tab -->
                    <div class="tab-pane fade" id="paid" role="tabpanel">
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead class="table-success">
                                    <tr>
                                        <th>#</th>
                                        <th>Date</th>
                                        <th>Day</th>
                                        <th>Meal</th>
                                        <th>Amount</th>
                                        <th>Paid On</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @{int paidIdx = 1;}
                                    @{var paidAttendances = attendancesList.Where(a => a.IsPaid).ToList();}
                                    @foreach (var attendance in paidAttendances)
                                    {
                                        <tr>
                                            <td>@paidIdx</td>
                                            <td><strong>@attendance.Date.ToString("dd MMM yyyy")</strong></td>
                                            <td>@attendance.Date.ToString("dddd")</td>
                                            <td>
                                                @if (attendance.MealType == "Breakfast")
                                                {
                                                    <span class="badge bg-warning text-dark"><i class="bi bi-sunrise me-1"></i>Breakfast</span>
                                                }
                                                else if (attendance.MealType == "Lunch")
                                                {
                                                    <span class="badge bg-info"><i class="bi bi-sun me-1"></i>Lunch</span>
                                                }
                                                else
                                                {
                                                    <span class="badge bg-dark"><i class="bi bi-moon me-1"></i>Dinner</span>
                                                }
                                            </td>
                                            <td><strong>PKR @attendance.Amount.ToString("N2")</strong></td>
                                            <td>
                                                @if (attendance.PaidAt.HasValue)
                                                {
                                                    <span class="text-success">@attendance.PaidAt.Value.ToString("dd MMM yyyy")</span>
                                                }
                                                else
                                                {
                                                    <span class="text-muted">-</span>
                                                }
                                            </td>
                                        </tr>
                                        paidIdx++;
                                    }
                                </tbody>
                                <tfoot>
                                    <tr class="table-light">
                                        <td colspan="4" class="text-end"><strong>Total Paid:</strong></td>
                                        <td colspan="2"><strong class="text-success">PKR @Model.PaidAmount.ToString("N2")</strong></td>
                                    </tr>
                                </tfoot>
                            </table>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>
