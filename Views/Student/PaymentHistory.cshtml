@model List<Semester_Project.Models.Payment>
@{
    ViewData["Title"] = "Payment History";
    var studentName = ViewBag.StudentName as string;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>@ViewData["Title"]</title>
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css">
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css">
    <style>
        body {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
        .sidebar {
            position: fixed;
            left: 0;
            top: 0;
            height: 100vh;
            width: 280px;
            background: linear-gradient(180deg, #2d3748 0%, #1a202c 100%);
            box-shadow: 4px 0 10px rgba(0,0,0,0.1);
            padding: 20px 0;
            overflow-y: auto;
            z-index: 1000;
        }
        .sidebar-header {
            padding: 20px;
            border-bottom: 1px solid rgba(255,255,255,0.1);
            margin-bottom: 20px;
        }
        .sidebar-brand {
            color: #fff;
            font-size: 1.3rem;
            font-weight: 700;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .sidebar-menu-item {
            display: flex;
            align-items: center;
            padding: 12px 20px;
            color: rgba(255,255,255,0.8);
            text-decoration: none;
            transition: all 0.3s;
            border-left: 3px solid transparent;
        }
        .sidebar-menu-item:hover, .sidebar-menu-item.active {
            background: rgba(255,255,255,0.1);
            color: #fff;
            border-left-color: #667eea;
        }
        .sidebar-menu-item i {
            font-size: 1.2rem;
            margin-right: 12px;
            width: 25px;
        }
        .main-content {
            margin-left: 280px;
            padding: 30px;
        }
        .content-card {
            background: white;
            border-radius: 15px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.1);
            padding: 30px;
        }
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 30px;
            padding-bottom: 20px;
            border-bottom: 2px solid #e2e8f0;
        }
        .page-title {
            font-size: 2rem;
            font-weight: 700;
            color: #2d3748;
            margin: 0;
        }
        .stats-row {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 20px;
            margin-bottom: 30px;
        }
        .stat-card {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            padding: 20px;
            border-radius: 10px;
            text-align: center;
        }
        .stat-card h3 {
            font-size: 2rem;
            margin: 0;
        }
        .stat-card p {
            margin: 5px 0 0;
            opacity: 0.9;
        }
        .table-responsive {
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 2px 8px rgba(0,0,0,0.05);
        }
        .table {
            margin: 0;
        }
        .table thead {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .table th {
            border: none;
            padding: 15px;
            font-weight: 600;
        }
        .table td {
            padding: 15px;
            vertical-align: middle;
        }
        .badge {
            padding: 6px 12px;
            border-radius: 20px;
            font-weight: 500;
        }
        .btn-back {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
            border: none;
            padding: 10px 25px;
            border-radius: 8px;
            text-decoration: none;
            display: inline-flex;
            align-items: center;
            gap: 8px;
            transition: all 0.3s;
        }
        .btn-back:hover {
            transform: translateY(-2px);
            box-shadow: 0 5px 15px rgba(102, 126, 234, 0.4);
            color: white;
        }
        .empty-state {
            text-align: center;
            padding: 60px 20px;
            color: #718096;
        }
        .empty-state i {
            font-size: 4rem;
            margin-bottom: 20px;
            opacity: 0.5;
        }
    </style>
</head>
<body>
    <!-- Sidebar -->
    <div class="sidebar">
        <div class="sidebar-header">
            <a href="/Student/Dashboard" class="sidebar-brand">
                <i class="bi bi-building"></i>
                <span>Mess Management</span>
            </a>
            <p class="text-white-50 mb-0 mt-2" style="font-size: 0.9rem;">Welcome, @studentName</p>
        </div>
        <nav>
            <a asp-action="Dashboard" asp-controller="Student" class="sidebar-menu-item">
                <i class="bi bi-speedometer2"></i>
                <span>Dashboard</span>
            </a>
            <a asp-action="ViewMenu" asp-controller="Student" class="sidebar-menu-item">
                <i class="bi bi-card-list"></i>
                <span>View Menu</span>
            </a>
            <a asp-action="MyAttendance" asp-controller="Student" class="sidebar-menu-item">
                <i class="bi bi-calendar-check"></i>
                <span>My Attendance</span>
            </a>
            <a asp-action="ViewBill" asp-controller="Student" class="sidebar-menu-item">
                <i class="bi bi-receipt"></i>
                <span>View Bill</span>
            </a>
            <a asp-action="PaymentHistory" asp-controller="Student" class="sidebar-menu-item active">
                <i class="bi bi-clock-history"></i>
                <span>Payment History</span>
            </a>
            <a asp-action="DigitalCard" asp-controller="Student" class="sidebar-menu-item">
                <i class="bi bi-credit-card"></i>
                <span>My Digital Card</span>
            </a>
            <a asp-action="Complaints" asp-controller="Student" class="sidebar-menu-item">
                <i class="bi bi-chat-left-text"></i>
                <span>Complaints</span>
            </a>
            <a asp-action="BillRecheckRequests" asp-controller="Student" class="sidebar-menu-item">
                <i class="bi bi-arrow-repeat"></i>
                <span>Bill Recheck</span>
            </a>
            <a asp-action="MyProfile" asp-controller="Student" class="sidebar-menu-item">
                <i class="bi bi-person"></i>
                <span>My Profile</span>
            </a>
            <a asp-action="Logout" asp-controller="Student" class="sidebar-menu-item">
                <i class="bi bi-box-arrow-right"></i>
                <span>Logout</span>
            </a>
        </nav>
    </div>

    <!-- Main Content -->
    <div class="main-content">
        <div class="content-card">
            <div class="page-header">
                <h1 class="page-title">
                    <i class="bi bi-clock-history me-2"></i>Payment History
                </h1>
                <a asp-action="Dashboard" class="btn-back">
                    <i class="bi bi-arrow-left"></i>
                    Back to Dashboard
                </a>
            </div>

            <!-- Stats -->
            <div class="stats-row">
                <div class="stat-card">
                    <h3>@Model.Count</h3>
                    <p>Total Payments</p>
                </div>
                <div class="stat-card">
                    <h3>Rs. @ViewBag.TotalPaid</h3>
                    <p>Total Amount Paid</p>
                </div>
            </div>

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>#</th>
                                <th>Date</th>
                                <th>Amount</th>
                                <th>Card</th>
                                <th>Transaction ID</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int index = 1;
                                foreach (var payment in Model)
                                {
                                    var displayDate = payment.PaidAt ?? payment.CreatedAt;
                                    <tr>
                                        <td>@index</td>
                                        <td>@displayDate.ToString("dd MMM yyyy, hh:mm tt")</td>
                                        <td><strong>Rs. @payment.Amount.ToString("N2")</strong></td>
                                        <td>
                                            @if (!string.IsNullOrEmpty(payment.CardBrand) && !string.IsNullOrEmpty(payment.CardLast4))
                                            {
                                                <span>@payment.CardBrand ****@payment.CardLast4</span>
                                            }
                                            else
                                            {
                                                <span class="text-muted">Stripe</span>
                                            }
                                        </td>
                                        <td><code>@payment.StripePaymentIntentId</code></td>
                                        <td>
                                            @if (payment.PaymentStatus == "Succeeded")
                                            {
                                                <span class="badge bg-success">
                                                    <i class="bi bi-check-circle me-1"></i>Succeeded
                                                </span>
                                            }
                                            else if (payment.PaymentStatus == "Pending")
                                            {
                                                <span class="badge bg-warning text-dark">
                                                    <i class="bi bi-clock me-1"></i>Pending
                                                </span>
                                            }
                                            else if (payment.PaymentStatus == "Failed")
                                            {
                                                <span class="badge bg-danger">
                                                    <i class="bi bi-x-circle me-1"></i>Failed
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="badge bg-secondary">
                                                    @payment.PaymentStatus
                                                </span>
                                            }
                                        </td>
                                    </tr>
                                    index++;
                                }
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="empty-state">
                    <i class="bi bi-inbox"></i>
                    <h4>No Payment History</h4>
                    <p>You haven't made any payments yet.</p>
                </div>
            }
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
