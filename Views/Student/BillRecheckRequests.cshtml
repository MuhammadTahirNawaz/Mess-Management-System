@model IEnumerable<Semester_Project.Models.BillRecheckRequest>

@{
    ViewData["Title"] = "My Bill Recheck Requests";
}

<div class="container mt-5">
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex justify-content-between align-items-center">
                <div>
                    <h2 class="fw-bold text-primary">
                        <i class="bi bi-receipt-cutoff me-2"></i>My Bill Recheck Requests
                    </h2>
                    <p class="text-muted">Track your bill recheck requests and admin responses</p>
                </div>
                <div>
                    <a asp-action="SubmitBillRecheck" class="btn btn-primary">
                        <i class="bi bi-plus-circle me-2"></i>Submit New Request
                    </a>
                    <a asp-action="Dashboard" class="btn btn-outline-secondary">
                        <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                    </a>
                </div>
            </div>
        </div>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
        </div>
    }

    @if (Model != null && Model.Any())
    {
        <div class="row">
            @foreach (var request in Model)
            {
                <div class="col-md-6 mb-4">
                    <div class="card shadow-sm h-100 @(request.Status == "Pending" ? "border-warning" : request.Status == "Reviewed" ? "border-info" : "border-success")">
                        <div class="card-header @(request.Status == "Pending" ? "bg-warning text-dark" : request.Status == "Reviewed" ? "bg-info text-white" : "bg-success text-white")">
                            <div class="d-flex justify-content-between align-items-center">
                                <h5 class="mb-0">
                                    <i class="bi bi-calendar-month me-2"></i>
                                    @(new DateTime(request.Year, request.Month, 1).ToString("MMMM")) @request.Year
                                </h5>
                                <span class="badge @(request.Status == "Pending" ? "bg-dark" : request.Status == "Reviewed" ? "bg-primary" : "bg-light text-dark")">
                                    @request.Status
                                </span>
                            </div>
                        </div>
                        <div class="card-body">
                            <div class="mb-3">
                                <h6 class="text-muted mb-2">
                                    <i class="bi bi-chat-left-text me-2"></i>Your Request:
                                </h6>
                                <p class="card-text">@request.RequestMessage</p>
                            </div>

                            @if (!string.IsNullOrEmpty(request.AdminResponse))
                            {
                                <div class="alert alert-info mb-3">
                                    <h6 class="alert-heading">
                                        <i class="bi bi-person-check me-2"></i>Admin Response:
                                    </h6>
                                    <p class="mb-0">@request.AdminResponse</p>
                                </div>
                            }

                            <div class="d-flex justify-content-between align-items-center text-muted small">
                                <span>
                                    <i class="bi bi-clock me-1"></i>
                                    Submitted: @request.RequestedAt.ToString("MMM dd, yyyy hh:mm tt")
                                </span>
                                @if (request.ReviewedAt.HasValue)
                                {
                                    <span>
                                        <i class="bi bi-check2-circle me-1"></i>
                                        Reviewed: @request.ReviewedAt.Value.ToString("MMM dd, yyyy hh:mm tt")
                                    </span>
                                }
                            </div>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="card shadow-sm border-0">
            <div class="card-body text-center py-5">
                <i class="bi bi-inbox text-muted" style="font-size: 4rem;"></i>
                <h4 class="mt-3 text-muted">No Recheck Requests Yet</h4>
                <p class="text-muted">You haven't submitted any bill recheck requests.</p>
                <a asp-action="SubmitBillRecheck" class="btn btn-primary mt-3">
                    <i class="bi bi-plus-circle me-2"></i>Submit Your First Request
                </a>
            </div>
        </div>
    }
</div>
