@{
    ViewData["Title"] = "Submit Bill Recheck Request";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-lg border-0">
                <div class="card-header bg-primary text-white">
                    <h3 class="mb-0">
                        <i class="bi bi-receipt-cutoff me-2"></i>Submit Bill Recheck Request
                    </h3>
                </div>
                <div class="card-body p-4">
                    @if (TempData["Error"] != null)
                    {
                        <div class="alert alert-danger alert-dismissible fade show" role="alert">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
                            <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                        </div>
                    }

                    <div class="alert alert-info" role="alert">
                        <i class="bi bi-info-circle-fill me-2"></i>
                        <strong>Note:</strong> Use this form to request admin to recheck your monthly bill if you believe there's an error in your attendance records or charges.
                    </div>

                    <form asp-action="SubmitBillRecheck" method="post">
                        @Html.AntiForgeryToken()

                        <div class="row mb-3">
                            <div class="col-md-6">
                                <label for="month" class="form-label fw-bold">
                                    <i class="bi bi-calendar-month me-1"></i>Month
                                </label>
                                <select class="form-select" id="month" name="month" required>
                                    <option value="">Select Month</option>
                                    <option value="1">January</option>
                                    <option value="2">February</option>
                                    <option value="3">March</option>
                                    <option value="4">April</option>
                                    <option value="5">May</option>
                                    <option value="6">June</option>
                                    <option value="7">July</option>
                                    <option value="8">August</option>
                                    <option value="9">September</option>
                                    <option value="10">October</option>
                                    <option value="11">November</option>
                                    <option value="12">December</option>
                                </select>
                            </div>

                            <div class="col-md-6">
                                <label for="year" class="form-label fw-bold">
                                    <i class="bi bi-calendar-event me-1"></i>Year
                                </label>
                                <input type="number" class="form-control" id="year" name="year" 
                                       min="2020" max="@(DateTime.Now.Year + 1)" 
                                       value="@DateTime.Now.Year" required>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label for="requestMessage" class="form-label fw-bold">
                                <i class="bi bi-chat-left-text me-1"></i>Request Message
                            </label>
                            <textarea class="form-control" id="requestMessage" name="requestMessage" 
                                      rows="6" maxlength="1000" required 
                                      placeholder="Please describe the issue with your bill in detail. Include specific dates or charges you want reviewed."></textarea>
                            <div class="form-text">
                                <i class="bi bi-info-circle me-1"></i>
                                Maximum 1000 characters. Be specific about what you want reviewed.
                            </div>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-action="BillRecheckRequests" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left me-2"></i>Cancel
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-send me-2"></i>Submit Request
                            </button>
                        </div>
                    </form>
                </div>
            </div>

            <div class="card shadow-sm border-0 mt-4">
                <div class="card-body">
                    <h5 class="card-title">
                        <i class="bi bi-lightbulb text-warning me-2"></i>Tips for Bill Recheck Requests
                    </h5>
                    <ul class="mb-0">
                        <li>Be specific about which dates or charges you want reviewed</li>
                        <li>Include any evidence or reasons for your request</li>
                        <li>You can only have one pending request per month/year</li>
                        <li>Admin will review and respond to your request within 2-3 business days</li>
                        <li>Check the status of your requests in "My Bill Recheck Requests"</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

<script>
    // Set current month by default
    document.addEventListener('DOMContentLoaded', function() {
        var monthSelect = document.getElementById('month');
        if (!monthSelect.value) {
            monthSelect.value = new Date().getMonth() + 1;
        }
    });
</script>
