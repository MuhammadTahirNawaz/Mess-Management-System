@model List<Semester_Project.Models.PaymentDeadline>

@{
    ViewData["Title"] = "Manage Payment Deadlines";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-danger text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="bi bi-calendar-x"></i> Manage Payment Deadlines</h3>
            <a asp-action="AddDeadline" class="btn btn-light">
                <i class="bi bi-plus-circle"></i> Add New Deadline
            </a>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (TempData["Error"] != null)
            {
                <div class="alert alert-danger alert-dismissible fade show">
                    <i class="bi bi-exclamation-circle"></i> @TempData["Error"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Month/Year</th>
                                <th>Deadline Date</th>
                                <th>Fine Amount (PKR)</th>
                                <th>Status</th>
                                <th>Days Left</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var deadline in Model)
                            {
                                var daysLeft = (deadline.DeadlineDate - DateTime.Now).Days;
                                var monthName = new DateTime(deadline.Year, deadline.Month, 1).ToString("MMMM");
                                
                                <tr>
                                    <td><strong>@monthName @deadline.Year</strong></td>
                                    <td>@deadline.DeadlineDate.ToString("dd MMM yyyy")</td>
                                    <td>PKR @deadline.FineAmount</td>
                                    <td>
                                        @if (deadline.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>
                                        @if (daysLeft > 0)
                                        {
                                            <span class="badge bg-info">@daysLeft days</span>
                                        }
                                        else if (daysLeft == 0)
                                        {
                                            <span class="badge bg-warning">Today</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">Overdue</span>
                                        }
                                    </td>
                                    <td>
                                        <button onclick="deleteDeadline(@deadline.Id)" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i> Delete
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> No payment deadlines set yet.
                </div>
            }

            <div class="mt-3">
                <a asp-action="Dashboard" asp-controller="Admin" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function deleteDeadline(id) {
            if (confirm('Are you sure you want to delete this deadline?')) {
                fetch('/Charges/DeleteDeadline/' + id, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                });
            }
        }
    </script>
}
