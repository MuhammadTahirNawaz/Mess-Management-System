@model List<Semester_Project.Models.MonthlyCharge>

@{
    ViewData["Title"] = "Manage Monthly Charges";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-header bg-primary text-white d-flex justify-content-between align-items-center">
            <h3 class="mb-0"><i class="bi bi-cash-stack"></i> Manage Monthly Charges</h3>
            <a asp-action="AddCharge" class="btn btn-light">
                <i class="bi bi-plus-circle"></i> Add New Charge
            </a>
        </div>
        <div class="card-body">
            @if (TempData["Success"] != null)
            {
                <div class="alert alert-success alert-dismissible fade show">
                    <i class="bi bi-check-circle"></i> @TempData["Success"]
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            }

            @if (Model.Any())
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-dark">
                            <tr>
                                <th>Charge Name</th>
                                <th>Amount (PKR)</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var charge in Model)
                            {
                                <tr>
                                    <td><strong>@charge.ChargeName</strong></td>
                                    <td>PKR @charge.Amount</td>
                                    <td>@(charge.Description ?? "N/A")</td>
                                    <td>
                                        @if (charge.IsActive)
                                        {
                                            <span class="badge bg-success">Active</span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-secondary">Inactive</span>
                                        }
                                    </td>
                                    <td>@charge.CreatedAt.ToString("dd MMM yyyy")</td>
                                    <td>
                                        <a asp-action="EditCharge" asp-route-id="@charge.Id" class="btn btn-sm btn-warning">
                                            <i class="bi bi-pencil"></i>
                                        </a>
                                        <button onclick="toggleStatus(@charge.Id)" class="btn btn-sm btn-info">
                                            <i class="bi bi-toggle-on"></i>
                                        </button>
                                        <button onclick="deleteCharge(@charge.Id)" class="btn btn-sm btn-danger">
                                            <i class="bi bi-trash"></i>
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
            else
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle"></i> No monthly charges configured yet.
                </div>
            }

            <div class="mt-3">
                <a asp-action="Dashboard" asp-controller="Admin" class="btn btn-secondary">
                    <i class="bi bi-arrow-left"></i> Back to Dashboard
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function toggleStatus(id) {
            if (confirm('Toggle charge status?')) {
                fetch('/Charges/ToggleStatus/' + id, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                });
            }
        }

        function deleteCharge(id) {
            if (confirm('Are you sure you want to delete this charge?')) {
                fetch('/Charges/DeleteCharge/' + id, {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/json'
                    }
                })
                .then(response => response.json())
                .then(data => {
                    if (data.success) {
                        location.reload();
                    } else {
                        alert('Error: ' + data.message);
                    }
                });
            }
        }
    </script>
}
