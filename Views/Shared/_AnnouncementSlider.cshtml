@* Announcement Slider Component - Compact *@
<div id="announcementCarousel" class="carousel slide mb-3" data-bs-ride="carousel" data-bs-interval="5000">
    <div class="carousel-indicators" style="bottom: -25px;">
        <button type="button" data-bs-target="#announcementCarousel" data-bs-slide-to="0" class="active" style="width: 10px; height: 3px;"></button>
        <button type="button" data-bs-target="#announcementCarousel" data-bs-slide-to="1" style="width: 10px; height: 3px;"></button>
        <button type="button" data-bs-target="#announcementCarousel" data-bs-slide-to="2" style="width: 10px; height: 3px;"></button>
    </div>
    <div class="carousel-inner rounded shadow">
        <div class="carousel-item active">
            <div class="announcement-slide bg-gradient-primary text-white px-4 py-2" style="background: linear-gradient(135deg, #667eea 0%, #764ba2 100%); height: 80px;">
                <div class="d-flex align-items-center h-100">
                    <i class="bi bi-megaphone fs-3 me-3"></i>
                    <div>
                        <h6 class="mb-1 fw-bold">Welcome to Mess Management System</h6>
                        <small>Streamlined meal tracking, payments, and attendance management</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="carousel-item">
            <div class="announcement-slide bg-gradient-success text-white px-4 py-2" style="background: linear-gradient(135deg, #11998e 0%, #38ef7d 100%); height: 80px;">
                <div class="d-flex align-items-center h-100">
                    <i class="bi bi-credit-card fs-3 me-3"></i>
                    <div>
                        <h6 class="mb-1 fw-bold">New Payment Integration</h6>
                        <small>Now pay your mess bills online through Stripe</small>
                    </div>
                </div>
            </div>
        </div>
        <div class="carousel-item">
            <div class="announcement-slide bg-gradient-warning text-white px-4 py-2" style="background: linear-gradient(135deg, #ee0979 0%, #ff6a00 100%); height: 80px;">
                <div class="d-flex align-items-center h-100">
                    <i class="bi bi-camera-video fs-3 me-3"></i>
                    <div>
                        <h6 class="mb-1 fw-bold">Face Recognition Attendance</h6>
                        <small>Advanced biometric attendance system now available</small>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <button class="carousel-control-prev" type="button" data-bs-target="#announcementCarousel" data-bs-slide="prev" style="width: 40px;">
        <span class="carousel-control-prev-icon" aria-hidden="true" style="width: 20px; height: 20px;"></span>
        <span class="visually-hidden">Previous</span>
    </button>
    <button class="carousel-control-next" type="button" data-bs-target="#announcementCarousel" data-bs-slide="next" style="width: 40px;">
        <span class="carousel-control-next-icon" aria-hidden="true" style="width: 20px; height: 20px;"></span>
        <span class="visually-hidden">Next</span>
    </button>
</div>

<style>
    .announcement-slide {
        display: flex;
        align-items: center;
        justify-content: flex-start;
        transition: all 0.3s ease;
    }
    
    .carousel-item {
        transition: transform 0.6s ease-in-out;
    }
    
    .carousel-control-prev-icon,
    .carousel-control-next-icon {
        background-color: rgba(0, 0, 0, 0.4);
        border-radius: 50%;
    }
    
    .carousel-indicators {
        margin-bottom: 0;
    }
</style>
