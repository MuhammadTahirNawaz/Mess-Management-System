@model Semester_Project.Models.StudentBillDetailsViewModel
@{
    ViewData["Title"] = "Bill Details - " + Model.StudentName;
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary mb-0"><i class="bi bi-receipt-cutoff me-2"></i>Detailed Bill Statement</h2>
        <a asp-action="ViewBills" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Bills
        </a>
    </div>

    <!-- Student Info Card -->
    <div class="card shadow mb-4">
        <div class="card-header bg-primary text-white">
            <h5 class="mb-0"><i class="bi bi-person-circle me-2"></i>Student Information</h5>
        </div>
        <div class="card-body">
            <div class="row">
                <div class="col-md-6">
                    <p class="mb-2"><strong>Name:</strong> @Model.StudentName</p>
                    <p class="mb-2"><strong>Email:</strong> @Model.StudentEmail</p>
                    <p class="mb-0"><strong>Permanent ID:</strong> <span class="text-primary fw-bold">@Model.PermanentID</span></p>
                </div>
                <div class="col-md-6">
                    <p class="mb-2"><strong>Total Meals:</strong> <span class="badge bg-info">@Model.TotalMeals</span></p>
                    <p class="mb-2"><strong>Unpaid Meals:</strong> <span class="badge bg-warning">@Model.UnpaidMeals</span></p>
                    <p class="mb-0"><strong>Paid Meals:</strong> <span class="badge bg-success">@Model.PaidMeals</span></p>
                </div>
            </div>
        </div>
    </div>

    <!-- Payment Summary -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow bg-danger text-white">
                <div class="card-body text-center">
                    <h6 class="card-title"><i class="bi bi-exclamation-triangle me-2"></i>Unpaid Amount</h6>
                    <h2 class="mb-0">PKR @Model.UnpaidAmount.ToString("N2")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow bg-success text-white">
                <div class="card-body text-center">
                    <h6 class="card-title"><i class="bi bi-check-circle me-2"></i>Paid Amount</h6>
                    <h2 class="mb-0">PKR @Model.PaidAmount.ToString("N2")</h2>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow bg-info text-white">
                <div class="card-body text-center">
                    <h6 class="card-title"><i class="bi bi-calculator me-2"></i>Total Amount</h6>
                    <h2 class="mb-0">PKR @Model.TotalAmount.ToString("N2")</h2>
                </div>
            </div>
        </div>
    </div>

    <!-- Payment Action -->
    @if (Model.UnpaidAmount > 0)
    {
        <div class="card shadow border-success mb-4">
            <div class="card-body">
                <h5 class="text-success mb-3"><i class="bi bi-cash-coin me-2"></i>Mark Payment as Received</h5>
                <p class="text-muted">Click the button below to mark all unpaid bills for this student as paid.</p>
                <button class="btn btn-success btn-lg" onclick="markAsPaid(@Model.StudentId, '@Model.StudentName', @Model.UnpaidAmount)">
                    <i class="bi bi-check-circle me-2"></i>Receive Payment of PKR @Model.UnpaidAmount.ToString("N2")
                </button>
                <div id="paymentResult" class="mt-3"></div>
            </div>
        </div>
    }

    <!-- Attendance History -->
    <div class="card shadow">
        <div class="card-header bg-secondary text-white">
            <h5 class="mb-0"><i class="bi bi-list-ul me-2"></i>Complete Meal History</h5>
        </div>
        <div class="card-body">
            @if (!Model.Attendances.Any())
            {
                <div class="alert alert-info">
                    <i class="bi bi-info-circle me-2"></i>No meal records found for this student.
                </div>
            }
            else
            {
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-secondary">
                            <tr>
                                <th>#</th>
                                <th>Date</th>
                                <th>Day</th>
                                <th>Meal Type</th>
                                <th>Amount</th>
                                <th>Payment Status</th>
                                <th>Paid On</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                int attendanceIndex = 1;
                            }
                            @foreach (var attendance in Model.Attendances)
                            {
                                <tr class="@(attendance.IsPaid ? "" : "table-warning")">
                                    <td>@attendanceIndex</td>
                                    <td><strong>@attendance.Date.ToString("dd MMM yyyy")</strong></td>
                                    <td>@attendance.Date.ToString("dddd")</td>
                                    <td>
                                        @if (attendance.MealType == "Breakfast")
                                        {
                                            <span class="badge bg-warning text-dark">
                                                <i class="bi bi-sunrise me-1"></i>Breakfast
                                            </span>
                                        }
                                        else if (attendance.MealType == "Lunch")
                                        {
                                            <span class="badge bg-info">
                                                <i class="bi bi-sun me-1"></i>Lunch
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-dark">
                                                <i class="bi bi-moon me-1"></i>Dinner
                                            </span>
                                        }
                                    </td>
                                    <td><strong>PKR @attendance.Amount.ToString("N2")</strong></td>
                                    <td>
                                        @if (attendance.IsPaid)
                                        {
                                            <span class="badge bg-success">
                                                <i class="bi bi-check-circle me-1"></i>Paid
                                            </span>
                                        }
                                        else
                                        {
                                            <span class="badge bg-danger">
                                                <i class="bi bi-x-circle me-1"></i>Unpaid
                                            </span>
                                        }
                                    </td>
                                    <td>
                                        @if (attendance.IsPaid && attendance.PaidAt.HasValue)
                                        {
                                            <span class="text-muted small">@attendance.PaidAt.Value.ToString("dd MMM yyyy")</span>
                                        }
                                        else
                                        {
                                            <span class="text-muted">-</span>
                                        }
                                    </td>
                                </tr>
                                attendanceIndex++;
                            }
                        </tbody>
                        <tfoot>
                            <tr class="table-light">
                                <td colspan="4" class="text-end"><strong>Totals:</strong></td>
                                <td><strong class="text-primary">PKR @Model.TotalAmount.ToString("N2")</strong></td>
                                <td>
                                    <span class="badge bg-success">@Model.PaidMeals Paid</span>
                                    <span class="badge bg-danger">@Model.UnpaidMeals Unpaid</span>
                                </td>
                                <td></td>
                            </tr>
                        </tfoot>
                    </table>
                </div>
            }
        </div>
    </div>
</div>

@section Scripts {
    <script>
        async function markAsPaid(studentId, studentName, amount) {
            if (!confirm(`Mark payment of PKR ${amount.toFixed(2)} as received from ${studentName}?\n\nThis will mark all unpaid meals as paid.`)) {
                return;
            }

            const resultDiv = document.getElementById('paymentResult');
            resultDiv.innerHTML = '<div class="spinner-border spinner-border-sm text-success" role="status"></div> Processing payment...';

            try {
                const response = await fetch('@Url.Action("MarkAsPaid", "AdminMenu")', {
                    method: 'POST',
                    headers: {
                        'Content-Type': 'application/x-www-form-urlencoded',
                    },
                    body: `studentId=${studentId}`
                });

                const data = await response.json();

                if (data.success) {
                    resultDiv.innerHTML = `
                        <div class="alert alert-success">
                            <h6 class="alert-heading"><i class="bi bi-check-circle me-2"></i>Payment Received!</h6>
                            <p class="mb-0">${data.message}</p>
                        </div>
                    `;
                    
                    // Reload page after 2 seconds to show updated data
                    setTimeout(() => {
                        location.reload();
                    }, 2000);
                } else {
                    resultDiv.innerHTML = `<div class="alert alert-danger"><i class="bi bi-x-circle me-2"></i>${data.message}</div>`;
                }
            } catch (error) {
                resultDiv.innerHTML = '<div class="alert alert-danger"><i class="bi bi-x-circle me-2"></i>An error occurred while processing payment.</div>';
            }
        }
    </script>
}
