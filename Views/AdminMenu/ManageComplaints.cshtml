@model List<Semester_Project.Models.Complaint>
@{
    ViewData["Title"] = "Manage Complaints";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary mb-0"><i class="bi bi-chat-left-text me-2"></i>Student Complaints</h2>
        <a asp-action="Dashboard" asp-controller="Admin" class="btn btn-secondary">
            <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
        </a>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-success">
            <i class="bi bi-check-circle me-2"></i>No complaints have been submitted. Great job!
        </div>
    }
    else
    {
        <!-- Summary Cards -->
        <div class="row mb-4">
            <div class="col-md-3">
                <div class="card shadow-sm bg-warning text-dark">
                    <div class="card-body text-center">
                        <h6 class="card-title"><i class="bi bi-clock-history me-1"></i>Pending</h6>
                        <h3 class="mb-0">@Model.Count(c => c.Status == "Pending")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm bg-info text-white">
                    <div class="card-body text-center">
                        <h6 class="card-title"><i class="bi bi-arrow-repeat me-1"></i>In Progress</h6>
                        <h3 class="mb-0">@Model.Count(c => c.Status == "InProgress")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm bg-success text-white">
                    <div class="card-body text-center">
                        <h6 class="card-title"><i class="bi bi-check-circle me-1"></i>Resolved</h6>
                        <h3 class="mb-0">@Model.Count(c => c.Status == "Resolved")</h3>
                    </div>
                </div>
            </div>
            <div class="col-md-3">
                <div class="card shadow-sm bg-secondary text-white">
                    <div class="card-body text-center">
                        <h6 class="card-title"><i class="bi bi-x-circle me-1"></i>Closed</h6>
                        <h3 class="mb-0">@Model.Count(c => c.Status == "Closed")</h3>
                    </div>
                </div>
            </div>
        </div>

        <!-- Complaints Table -->
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-primary">
                            <tr>
                                <th>#</th>
                                <th>Student</th>
                                <th>Subject</th>
                                <th>Description</th>
                                <th>Status</th>
                                <th>Submitted</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var complaint in Model.Select((c, index) => new { Complaint = c, Index = index + 1 }))
                            {
                                <tr>
                                    <td>@complaint.Index</td>
                                    <td>
                                        <strong>@complaint.Complaint.Student?.Name</strong><br />
                                        <small class="text-muted">@complaint.Complaint.Student?.Email</small>
                                    </td>
                                    <td><strong>@complaint.Complaint.Subject</strong></td>
                                    <td>
                                        <small>@(complaint.Complaint.Description.Length > 50 ? complaint.Complaint.Description.Substring(0, 50) + "..." : complaint.Complaint.Description)</small>
                                    </td>
                                    <td>
                                        <span class="badge 
                                            @(complaint.Complaint.Status == "Resolved" ? "bg-success" : 
                                              complaint.Complaint.Status == "InProgress" ? "bg-info" : 
                                              complaint.Complaint.Status == "Closed" ? "bg-secondary" : "bg-warning text-dark")">
                                            @complaint.Complaint.Status
                                        </span>
                                    </td>
                                    <td>
                                        <small>@complaint.Complaint.CreatedAt.ToString("dd MMM yyyy")<br />@complaint.Complaint.CreatedAt.ToString("hh:mm tt")</small>
                                    </td>
                                    <td>
                                        <button class="btn btn-sm btn-primary" onclick="viewComplaint(@complaint.Complaint.Id)" data-bs-toggle="modal" data-bs-target="#complaintModal">
                                            <i class="bi bi-eye me-1"></i>View
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- Complaint Details Modal -->
<div class="modal fade" id="complaintModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-chat-left-text me-2"></i>Complaint Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="complaintDetails">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const complaints = @Html.Raw(Json.Serialize(Model));

        function viewComplaint(id) {
            const complaint = complaints.find(c => c.id === id);
            if (!complaint) return;

            const statusColor = complaint.status === 'Resolved' ? 'success' : 
                              complaint.status === 'InProgress' ? 'info' : 
                              complaint.status === 'Closed' ? 'secondary' : 'warning';

            let html = `
                <div class="mb-3">
                    <h6><strong>Student Information</strong></h6>
                    <p class="mb-1"><strong>Name:</strong> ${complaint.student?.name || 'N/A'}</p>
                    <p class="mb-1"><strong>Email:</strong> ${complaint.student?.email || 'N/A'}</p>
                    <p><strong>Permanent ID:</strong> ${complaint.student?.permanentID || 'N/A'}</p>
                </div>
                <hr>
                <div class="mb-3">
                    <h6><strong>Complaint Details</strong></h6>
                    <p class="mb-1"><strong>Subject:</strong> ${complaint.subject}</p>
                    <p class="mb-1"><strong>Description:</strong></p>
                    <p>${complaint.description}</p>
                    <p class="mb-1"><strong>Status:</strong> <span class="badge bg-${statusColor}">${complaint.status}</span></p>
                    <p><strong>Submitted:</strong> ${new Date(complaint.createdAt).toLocaleString()}</p>
                </div>
                <hr>
                <form id="updateForm">
                    <div class="mb-3">
                        <label class="form-label"><strong>Update Status</strong></label>
                        <select class="form-select" id="status" required>
                            <option value="Pending" ${complaint.status === 'Pending' ? 'selected' : ''}>Pending</option>
                            <option value="InProgress" ${complaint.status === 'InProgress' ? 'selected' : ''}>In Progress</option>
                            <option value="Resolved" ${complaint.status === 'Resolved' ? 'selected' : ''}>Resolved</option>
                            <option value="Closed" ${complaint.status === 'Closed' ? 'selected' : ''}>Closed</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label"><strong>Admin Response</strong></label>
                        <textarea class="form-control" id="response" rows="3">${complaint.adminResponse || ''}</textarea>
                    </div>
                    <div class="d-grid gap-2">
                        <button type="submit" class="btn btn-primary">
                            <i class="bi bi-save me-1"></i>Update Complaint
                        </button>
                    </div>
                </form>
            `;

            document.getElementById('complaintDetails').innerHTML = html;

            document.getElementById('updateForm').onsubmit = function(e) {
                e.preventDefault();
                updateComplaint(id);
            };
        }

        function updateComplaint(id) {
            const status = document.getElementById('status').value;
            const response = document.getElementById('response').value;

            $.ajax({
                url: '@Url.Action("UpdateComplaintStatus", "AdminMenu")',
                type: 'POST',
                data: {
                    id: id,
                    status: status,
                    response: response
                },
                success: function (result) {
                    if (result.success) {
                        $('#complaintModal').modal('hide');
                        Swal.fire({
                            icon: 'success',
                            title: 'Success!',
                            text: result.message,
                            timer: 2000,
                            showConfirmButton: false
                        }).then(() => {
                            window.location.reload();
                        });
                    } else {
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: result.message
                        });
                    }
                },
                error: function () {
                    Swal.fire({
                        icon: 'error',
                        title: 'Error!',
                        text: 'An error occurred while updating the complaint'
                    });
                }
            });
        }
    </script>
}
