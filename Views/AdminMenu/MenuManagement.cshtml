@model IEnumerable<Semester_Project.Models.MenuItem>
@{
    ViewData["Title"] = "Menu Management";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary"><i class="bi bi-calendar-week me-2"></i>Menu Management</h2>
        <a asp-action="AddMenuItem" class="btn btn-success">
            <i class="bi bi-plus-circle me-2"></i>Add Menu Item
        </a>
    </div>

    @if (TempData["Success"] != null)
    {
        <div class="alert alert-success alert-dismissible fade show" role="alert">
            <i class="bi bi-check-circle-fill me-2"></i>@TempData["Success"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (TempData["Error"] != null)
    {
        <div class="alert alert-danger alert-dismissible fade show" role="alert">
            <i class="bi bi-exclamation-triangle-fill me-2"></i>@TempData["Error"]
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No menu items added yet. Click "Add Menu Item" to get started.
        </div>
    }
    else
    {
        @foreach (var day in new[] { "Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday" })
        {
            var dayItems = Model.Where(m => m.DayOfWeek == day).ToList();
            if (dayItems.Any())
            {
                <div class="card mb-4 shadow-sm">
                    <div class="card-header bg-primary text-white">
                        <h5 class="mb-0"><i class="bi bi-calendar-day me-2"></i>@day</h5>
                    </div>
                    <div class="card-body">
                        <div class="row">
                            @foreach (var mealType in new[] { "Breakfast", "Lunch", "Dinner" })
                            {
                                var mealItems = dayItems.Where(m => m.MealType == mealType).ToList();
                                if (mealItems.Any())
                                {
                                    <div class="col-md-4 mb-3">
                                        <h6 class="text-success"><i class="bi bi-cup-hot me-2"></i>@mealType</h6>
                                        <table class="table table-sm table-bordered">
                                            <thead>
                                                <tr>
                                                    <th>Item</th>
                                                    <th>Price</th>
                                                    <th>Actions</th>
                                                </tr>
                                            </thead>
                                            <tbody>
                                                @foreach (var item in mealItems)
                                                {
                                                    <tr class="@(item.IsActive ? "" : "table-secondary")">
                                                        <td>
                                                            @item.ItemName
                                                            @if (!string.IsNullOrEmpty(item.Description))
                                                            {
                                                                <br><small class="text-muted">@item.Description</small>
                                                            }
                                                        </td>
                                                        <td>Rs. @item.Price.ToString("N2")</td>
                                                        <td>
                                                            <a asp-action="EditMenuItem" asp-route-id="@item.Id" class="btn btn-sm btn-warning">
                                                                <i class="bi bi-pencil"></i>
                                                            </a>
                                                            <form asp-action="DeleteMenuItem" asp-route-id="@item.Id" method="post" style="display:inline;" onsubmit="return confirm('Are you sure you want to delete this item?');">
                                                                @Html.AntiForgeryToken()
                                                                <button type="submit" class="btn btn-sm btn-danger">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </form>
                                                        </td>
                                                    </tr>
                                                }
                                            </tbody>
                                        </table>
                                    </div>
                                }
                            }
                        </div>
                    </div>
                </div>
            }
        }
    }
</div>
