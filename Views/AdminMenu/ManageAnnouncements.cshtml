@model List<Semester_Project.Models.Announcement>
@{
    ViewData["Title"] = "Manage Announcements";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2 class="text-primary mb-0"><i class="bi bi-megaphone me-2"></i>Manage Announcements</h2>
        <div>
            <button class="btn btn-success me-2" data-bs-toggle="modal" data-bs-target="#newAnnouncementModal">
                <i class="bi bi-plus-circle me-1"></i>New Announcement
            </button>
            <a asp-action="Dashboard" asp-controller="Admin" class="btn btn-secondary">
                <i class="bi bi-arrow-left me-1"></i>Back to Dashboard
            </a>
        </div>
    </div>

    <!-- Summary Cards -->
    <div class="row mb-4">
        <div class="col-md-4">
            <div class="card shadow-sm bg-success text-white">
                <div class="card-body text-center">
                    <h6 class="card-title"><i class="bi bi-check-circle me-1"></i>Active</h6>
                    <h3 class="mb-0">@Model.Count(a => a.IsActive)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm bg-secondary text-white">
                <div class="card-body text-center">
                    <h6 class="card-title"><i class="bi bi-x-circle me-1"></i>Inactive</h6>
                    <h3 class="mb-0">@Model.Count(a => !a.IsActive)</h3>
                </div>
            </div>
        </div>
        <div class="col-md-4">
            <div class="card shadow-sm bg-danger text-white">
                <div class="card-body text-center">
                    <h6 class="card-title"><i class="bi bi-exclamation-triangle me-1"></i>Urgent</h6>
                    <h3 class="mb-0">@Model.Count(a => a.Priority == "Urgent" && a.IsActive)</h3>
                </div>
            </div>
        </div>
    </div>

    @if (Model.Count == 0)
    {
        <div class="alert alert-info">
            <i class="bi bi-info-circle me-2"></i>No announcements have been created yet. Click "New Announcement" to create one.
        </div>
    }
    else
    {
        <div class="card shadow">
            <div class="card-body">
                <div class="table-responsive">
                    <table class="table table-hover">
                        <thead class="table-primary">
                            <tr>
                                <th>#</th>
                                <th>Title</th>
                                <th>Priority</th>
                                <th>Status</th>
                                <th>Created</th>
                                <th>Expires</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var announcement in Model.Select((a, index) => new { Announcement = a, Index = index + 1 }))
                            {
                                <tr>
                                    <td>@announcement.Index</td>
                                    <td><strong>@announcement.Announcement.Title</strong></td>
                                    <td>
                                        <span class="badge 
                                            @(announcement.Announcement.Priority == "Urgent" ? "bg-danger" : 
                                              announcement.Announcement.Priority == "High" ? "bg-warning text-dark" : 
                                              announcement.Announcement.Priority == "Normal" ? "bg-info" : "bg-secondary")">
                                            @announcement.Announcement.Priority
                                        </span>
                                    </td>
                                    <td>
                                        <span class="badge @(announcement.Announcement.IsActive ? "bg-success" : "bg-secondary")">
                                            @(announcement.Announcement.IsActive ? "Active" : "Inactive")
                                        </span>
                                    </td>
                                    <td>
                                        <small>@announcement.Announcement.CreatedAt.ToString("dd MMM yyyy")<br />@announcement.Announcement.CreatedAt.ToString("hh:mm tt")</small>
                                    </td>
                                    <td>
                                        @if (announcement.Announcement.ExpiresAt.HasValue)
                                        {
                                            <small>@announcement.Announcement.ExpiresAt.Value.ToString("dd MMM yyyy")</small>
                                        }
                                        else
                                        {
                                            <small class="text-muted">No expiry</small>
                                        }
                                    </td>
                                    <td>
                                        <div class="btn-group btn-group-sm" role="group">
                                            <button class="btn btn-primary" onclick="editAnnouncement(@announcement.Announcement.Id)" data-bs-toggle="modal" data-bs-target="#editModal">
                                                <i class="bi bi-pencil"></i>
                                            </button>
                                            <button class="btn btn-info" onclick="viewAnnouncement(@announcement.Announcement.Id)" data-bs-toggle="modal" data-bs-target="#viewModal">
                                                <i class="bi bi-eye"></i>
                                            </button>
                                            <button class="btn btn-warning" onclick="toggleStatus(@announcement.Announcement.Id)">
                                                <i class="bi bi-toggle-@(announcement.Announcement.IsActive ? "on" : "off")"></i>
                                            </button>
                                            <button class="btn btn-danger" onclick="deleteAnnouncement(@announcement.Announcement.Id)">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </div>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>

<!-- New Announcement Modal -->
<div class="modal fade" id="newAnnouncementModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-success text-white">
                <h5 class="modal-title"><i class="bi bi-plus-circle me-2"></i>Create New Announcement</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="announcementForm">
                @Html.AntiForgeryToken()
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="title" class="form-label"><strong>Title</strong></label>
                        <input type="text" class="form-control" id="title" name="title" maxlength="200" required>
                    </div>
                    <div class="mb-3">
                        <label for="content" class="form-label"><strong>Content</strong></label>
                        <textarea class="form-control" id="content" name="content" rows="5" maxlength="2000" required></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="priority" class="form-label"><strong>Priority</strong></label>
                            <select class="form-select" id="priority" name="priority" required>
                                <option value="Low">Low</option>
                                <option value="Normal" selected>Normal</option>
                                <option value="High">High</option>
                                <option value="Urgent">Urgent</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="expiresAt" class="form-label"><strong>Expires At (Optional)</strong></label>
                            <input type="datetime-local" class="form-control" id="expiresAt" name="expiresAt">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="visibleFrom" class="form-label"><strong>Visible From (Optional)</strong></label>
                            <input type="datetime-local" class="form-control" id="visibleFrom" name="visibleFrom">
                            <small class="text-muted">Leave empty to show immediately</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="visibleTo" class="form-label"><strong>Visible To (Optional)</strong></label>
                            <input type="datetime-local" class="form-control" id="visibleTo" name="visibleTo">
                            <small class="text-muted">Leave empty for no end time</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-success">Create Announcement</button>
                </div>
            </form>
        </div>
    </div>
</div>

<!-- View Announcement Modal -->
<div class="modal fade" id="viewModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-info text-white">
                <h5 class="modal-title"><i class="bi bi-eye me-2"></i>Announcement Details</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body" id="announcementDetails">
                <!-- Content loaded dynamically -->
            </div>
        </div>
    </div>
</div>

<!-- Edit Announcement Modal -->
<div class="modal fade" id="editModal" tabindex="-1">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header bg-primary text-white">
                <h5 class="modal-title"><i class="bi bi-pencil me-2"></i>Edit Announcement</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
            </div>
            <form id="editAnnouncementForm">
                @Html.AntiForgeryToken()
                <input type="hidden" id="editId" name="id">
                <div class="modal-body">
                    <div class="mb-3">
                        <label for="editTitle" class="form-label"><strong>Title</strong></label>
                        <input type="text" class="form-control" id="editTitle" name="title" maxlength="200" required>
                    </div>
                    <div class="mb-3">
                        <label for="editContent" class="form-label"><strong>Content</strong></label>
                        <textarea class="form-control" id="editContent" name="content" rows="5" maxlength="2000" required></textarea>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="editPriority" class="form-label"><strong>Priority</strong></label>
                            <select class="form-select" id="editPriority" name="priority" required>
                                <option value="Low">Low</option>
                                <option value="Normal">Normal</option>
                                <option value="High">High</option>
                                <option value="Urgent">Urgent</option>
                            </select>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="editExpiresAt" class="form-label"><strong>Expires At (Optional)</strong></label>
                            <input type="datetime-local" class="form-control" id="editExpiresAt" name="expiresAt">
                        </div>
                    </div>
                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="editVisibleFrom" class="form-label"><strong>Visible From (Optional)</strong></label>
                            <input type="datetime-local" class="form-control" id="editVisibleFrom" name="visibleFrom">
                            <small class="text-muted">Leave empty to show immediately</small>
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="editVisibleTo" class="form-label"><strong>Visible To (Optional)</strong></label>
                            <input type="datetime-local" class="form-control" id="editVisibleTo" name="visibleTo">
                            <small class="text-muted">Leave empty for no end time</small>
                        </div>
                    </div>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="submit" class="btn btn-primary">Update Announcement</button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const announcements = @Html.Raw(Json.Serialize(Model));

        $(document).ready(function () {
            console.log('Announcement management page loaded');
            
            $('#announcementForm').on('submit', function (e) {
                e.preventDefault();
                console.log('Create announcement form submitted');

                const token = $('#announcementForm input[name="__RequestVerificationToken"]').val();
                const expiresAtVal = $('#expiresAt').val();
                
                const visibleFromVal = $('#visibleFrom').val();
                const visibleToVal = $('#visibleTo').val();
                
                const formData = {
                    title: $('#title').val(),
                    content: $('#content').val(),
                    priority: $('#priority').val(),
                    expiresAt: expiresAtVal ? expiresAtVal : '',
                    visibleFrom: visibleFromVal ? visibleFromVal : '',
                    visibleTo: visibleToVal ? visibleToVal : '',
                    __RequestVerificationToken: token
                };

                console.log('Form data:', formData);

                $.ajax({
                    url: '@Url.Action("CreateAnnouncement", "AdminMenu")',
                    type: 'POST',
                    data: formData,
                    success: function (response) {
                        console.log('Success response:', response);
                        if (response.success) {
                            $('#newAnnouncementModal').modal('hide');
                            $('#announcementForm')[0].reset();
                            
                            if (typeof Swal !== 'undefined') {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Success!',
                                    text: response.message,
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => {
                                    window.location.reload();
                                });
                            } else {
                                alert(response.message);
                                window.location.reload();
                            }
                        } else {
                            if (typeof Swal !== 'undefined') {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error!',
                                    text: response.message
                                });
                            } else {
                                alert('Error: ' + response.message);
                            }
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('AJAX Error - Status:', status);
                        console.error('Error:', error);
                        console.error('Response:', xhr.responseText);
                        
                        if (typeof Swal !== 'undefined') {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: 'An error occurred: ' + (xhr.responseText || error)
                            });
                        } else {
                            alert('Error occurred: ' + (xhr.responseText || error));
                        }
                    }
                });
            });

            $('#editAnnouncementForm').on('submit', function (e) {
                e.preventDefault();

                const token = $('#editAnnouncementForm input[name="__RequestVerificationToken"]').val();
                const editExpiresAtVal = $('#editExpiresAt').val();
                const editVisibleFromVal = $('#editVisibleFrom').val();
                const editVisibleToVal = $('#editVisibleTo').val();
                
                const formData = {
                    id: $('#editId').val(),
                    title: $('#editTitle').val(),
                    content: $('#editContent').val(),
                    priority: $('#editPriority').val(),
                    expiresAt: editExpiresAtVal ? editExpiresAtVal : '',
                    visibleFrom: editVisibleFromVal ? editVisibleFromVal : '',
                    visibleTo: editVisibleToVal ? editVisibleToVal : '',
                    __RequestVerificationToken: token
                };

                $.ajax({
                    url: '@Url.Action("UpdateAnnouncement", "AdminMenu")',
                    type: 'POST',
                    data: formData,
                    success: function (response) {
                        if (response.success) {
                            $('#editModal').modal('hide');
                            Swal.fire({
                                icon: 'success',
                                title: 'Success!',
                                text: response.message,
                                timer: 2000,
                                showConfirmButton: false
                            }).then(() => {
                                window.location.reload();
                            });
                        } else {
                            Swal.fire({
                                icon: 'error',
                                title: 'Error!',
                                text: response.message
                            });
                        }
                    },
                    error: function (xhr, status, error) {
                        console.error('Error details:', xhr.responseText);
                        Swal.fire({
                            icon: 'error',
                            title: 'Error!',
                            text: 'An error occurred while updating the announcement'
                        });
                    }
                });
            });
        });

        function editAnnouncement(id) {
            const announcement = announcements.find(a => a.id === id);
            if (!announcement) return;

            $('#editId').val(announcement.id);
            $('#editTitle').val(announcement.title);
            $('#editContent').val(announcement.content);
            $('#editPriority').val(announcement.priority);
            
            if (announcement.expiresAt) {
                const date = new Date(announcement.expiresAt);
                const offset = date.getTimezoneOffset();
                const localDate = new Date(date.getTime() - (offset * 60 * 1000));
                $('#editExpiresAt').val(localDate.toISOString().slice(0, 16));
            } else {
                $('#editExpiresAt').val('');
            }
            
            if (announcement.visibleFrom) {
                const date = new Date(announcement.visibleFrom);
                const offset = date.getTimezoneOffset();
                const localDate = new Date(date.getTime() - (offset * 60 * 1000));
                $('#editVisibleFrom').val(localDate.toISOString().slice(0, 16));
            } else {
                $('#editVisibleFrom').val('');
            }
            
            if (announcement.visibleTo) {
                const date = new Date(announcement.visibleTo);
                const offset = date.getTimezoneOffset();
                const localDate = new Date(date.getTime() - (offset * 60 * 1000));
                $('#editVisibleTo').val(localDate.toISOString().slice(0, 16));
            } else {
                $('#editVisibleTo').val('');
            }
        }

        function viewAnnouncement(id) {
            const announcement = announcements.find(a => a.id === id);
            if (!announcement) return;

            const priorityColor = announcement.priority === 'Urgent' ? 'danger' :
                                announcement.priority === 'High' ? 'warning' :
                                announcement.priority === 'Normal' ? 'info' : 'secondary';

            let html = `
                <div class="mb-3">
                    <h5><strong>${announcement.title}</strong></h5>
                    <p class="mb-1">
                        <span class="badge bg-${priorityColor}">${announcement.priority}</span>
                        <span class="badge bg-${announcement.isActive ? 'success' : 'secondary'}">${announcement.isActive ? 'Active' : 'Inactive'}</span>
                    </p>
                </div>
                <hr>
                <div class="mb-3">
                    <p style="white-space: pre-line">${announcement.content}</p>
                </div>
                <hr>
                <div>
                    <p class="mb-1"><strong>Created:</strong> ${new Date(announcement.createdAt).toLocaleString()}</p>
                    ${announcement.expiresAt ? `<p class="mb-0"><strong>Expires:</strong> ${new Date(announcement.expiresAt).toLocaleDateString()}</p>` : ''}
                </div>
            `;

            document.getElementById('announcementDetails').innerHTML = html;
        }

        function toggleStatus(id) {
            Swal.fire({
                title: 'Toggle Status?',
                text: 'This will change the announcement visibility to students',
                icon: 'question',
                showCancelButton: true,
                confirmButtonText: 'Yes, toggle it!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("ToggleAnnouncementStatus", "AdminMenu")',
                        type: 'POST',
                        data: { id: id },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Success!',
                                    text: response.message,
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => {
                                    window.location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error!',
                                    text: response.message
                                });
                            }
                        }
                    });
                }
            });
        }

        function deleteAnnouncement(id) {
            Swal.fire({
                title: 'Delete Announcement?',
                text: 'This action cannot be undone!',
                icon: 'warning',
                showCancelButton: true,
                confirmButtonText: 'Yes, delete it!',
                confirmButtonColor: '#d33',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    $.ajax({
                        url: '@Url.Action("DeleteAnnouncement", "AdminMenu")',
                        type: 'POST',
                        data: { id: id },
                        success: function (response) {
                            if (response.success) {
                                Swal.fire({
                                    icon: 'success',
                                    title: 'Deleted!',
                                    text: response.message,
                                    timer: 2000,
                                    showConfirmButton: false
                                }).then(() => {
                                    window.location.reload();
                                });
                            } else {
                                Swal.fire({
                                    icon: 'error',
                                    title: 'Error!',
                                    text: response.message
                                });
                            }
                        }
                    });
                }
            });
        }
    </script>
}
